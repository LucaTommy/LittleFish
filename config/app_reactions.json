        "figma": [
          {"text": "Design mode. Nice.", "min_stage": "stranger"},
          {"text": "Making things pretty?", "min_stage": "acquaintance"},
          {"text": "I'd critique the kerning but I don't have hands.", "min_stage": "friend"}
